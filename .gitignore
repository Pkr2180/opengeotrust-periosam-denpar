# Metrics — keep only final benchmark results
outputs/metrics/*
!outputs/metrics/.gitkeep
!outputs/metrics/eval_results_final.json
!outputs/metrics/multitask_history_final.json

# Duplicate nested subdirectories created during development
outputs/figures/figures/
outputs/metrics/metrics/

# K-fold CV — fold data and checkpoints live in Modal volume, not repo
outputs/kfold/fold_*/
!outputs/kfold/kfold_summary.json

# Temporary debug scripts
outputs/check_bone.py

